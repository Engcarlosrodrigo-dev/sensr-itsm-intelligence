    def generate_tickets(self, n: int = 200) -> list:
        tickets = []
        now = datetime.now()
        random.seed(42)

        for i in range(1, n + 1):
            category = random.choice(self.CATEGORIES)
            priority = random.choices(self.PRIORITIES, weights=self.PRIORITY_WEIGHTS)[0]
            status = random.choices(self.STATUSES_TICKET, weights=self.STATUS_WEIGHTS)[0]
            agent = random.choice(self.AGENTS)
            requester = random.choice(self.REQUESTERS)
            sla = self.SLA_BY_PRIORITY[priority]

            created_at = now - timedelta(
                days=random.randint(0, 30),
                hours=random.randint(0, 23),
                minutes=random.randint(0, 59)
            )

            # Tempo de primeira resposta
            response_time_h = random.uniform(0.5, sla["response_hours"] * 1.5)
            responded_at = created_at + timedelta(hours=response_time_h)

            # Tempo de resolução (só se resolvido/fechado)
            resolved_at = None
            resolution_time_h = None
            sla_met = None

            if status in ["Resolvido", "Fechado"]:
                resolution_time_h = random.uniform(
                    sla["resolution_hours"] * 0.3,
                    sla["resolution_hours"] * 1.8
                )
                resolved_at = created_at + timedelta(hours=resolution_time_h)
                sla_met = resolution_time_h <= sla["resolution_hours"]

            titles = self.TICKET_TITLES.get(category, ["Solicitação genérica"])
            title = random.choice(titles)

            tickets.append({
                "id": f"TKT-{str(i).zfill(4)}",
                "title": title,
                "category": category,
                "priority": priority,
                "status": status,
                "requester": requester,
                "agent": agent["name"],
                "agent_team": agent["team"],
                "created_at": created_at.isoformat(),
                "responded_at": responded_at.isoformat(),
                "resolved_at": resolved_at.isoformat() if resolved_at else None,
                "response_time_hours": round(response_time_h, 2),
                "resolution_time_hours": round(resolution_time_h, 2) if resolution_time_h else None,
                "sla_response_limit": sla["response_hours"],
                "sla_resolution_limit": sla["resolution_hours"],
                "sla_met": sla_met,
                "satisfaction_score": random.choice([1,2,3,4,5,None,None]) if status == "Fechado" else None,
                "reopen_count": random.choice([0,0,0,0,1,1,2]),
            })

        return tickets

    def generate_projects(self, n: int = 12) -> list:
        projects = []
        now = datetime.now()
        random.seed(99)

        for i, name in enumerate(self.PROJECT_NAMES[:n], 1):
            status = random.choice(self.STATUSES_PROJECT)
            start = now - timedelta(days=random.randint(30, 180))
            end_planned = start + timedelta(days=random.randint(30, 120))
            progress = {
                "Planejamento": random.randint(5, 15),
                "Em Execução": random.randint(20, 75),
                "Em Revisão": random.randint(80, 95),
                "Concluído": 100,
                "Pausado": random.randint(10, 60),
            }[status]

            budget_planned = random.choice([50000, 80000, 120000, 200000, 350000])
            budget_used = round(budget_planned * random.uniform(0.3, 1.2), 2)

            projects.append({
                "id": f"PRJ-{str(i).zfill(3)}",
                "name": name,
                "status": status,
                "priority": random.choice(["Alta", "Média", "Baixa"]),
                "manager": random.choice(self.AGENTS)["name"],
                "team_size": random.randint(2, 8),
                "progress_pct": progress,
                "start_date": start.strftime("%Y-%m-%d"),
                "end_date_planned": end_planned.strftime("%Y-%m-%d"),
                "end_date_actual": (end_planned + timedelta(days=random.randint(-10,30))).strftime("%Y-%m-%d") if status == "Concluído" else None,
                "budget_planned": budget_planned,
                "budget_used": budget_used,
                "budget_variance_pct": round((budget_used / budget_planned - 1) * 100, 1),
                "tasks_total": random.randint(10, 50),
                "tasks_done": int(random.randint(10, 50) * progress / 100),
                "risks": random.choice(["Baixo", "Médio", "Alto"]),
                "category": random.choice(["Infraestrutura", "Segurança", "Software", "Cloud"]),
            })

        return projects

    def generate_sla_report(self, period_days: int = 30) -> dict:
        random.seed(7)
        by_priority = {}
        for p in self.PRIORITIES:
            total = random.randint(20, 80)
            met = int(total * random.uniform(0.70, 0.98))
            by_priority[p] = {
                "total": total,
                "met": met,
                "breached": total - met,
                "compliance_pct": round(met / total * 100, 1),
                "avg_resolution_hours": round(random.uniform(
                    self.SLA_BY_PRIORITY[p]["resolution_hours"] * 0.6,
                    self.SLA_BY_PRIORITY[p]["resolution_hours"] * 1.2
                ), 1),
            }

        total_all = sum(v["total"] for v in by_priority.values())
        met_all = sum(v["met"] for v in by_priority.values())

        by_category = {}
        for cat in self.CATEGORIES:
            total = random.randint(5, 30)
            met = int(total * random.uniform(0.65, 0.99))
            by_category[cat] = {
                "total": total,
                "met": met,
                "compliance_pct": round(met / total * 100, 1),
            }

        return {
            "period_days": period_days,
            "generated_at": datetime.now().isoformat(),
            "overall": {
                "total_tickets": total_all,
                "sla_met": met_all,
                "sla_breached": total_all - met_all,
                "compliance_pct": round(met_all / total_all * 100, 1),
            },
            "by_priority": by_priority,
            "by_category": by_category,
        }

