"""
sensr.IT API Client
Consome a API REST da plataforma ITSM sensr.IT.
Em modo mock gera dados realistas para desenvolvimento e portfólio.
"""

import json
import logging
import random
from datetime import datetime, timedelta
from typing import Optional

logger = logging.getLogger("SensrAPIClient")


class SensrAPIClient:
    """
    Cliente oficial da API sensr.IT.

    Endpoints suportados:
    - GET /tickets          → Lista de chamados de suporte
    - GET /tickets/{id}     → Detalhe de um chamado
    - GET /projects         → Lista de projetos
    - GET /projects/{id}    → Detalhe de um projeto
    - GET /sla              → Relatório de SLA
    - GET /kpis             → KPIs gerenciais consolidados
    - GET /categories       → Categorias de chamados
    - GET /agents           → Agentes/atendentes disponíveis

    Em produção: configure BASE_URL e API_KEY via variáveis de ambiente.
    Em desenvolvimento: usa MockDataGenerator automaticamente.
    """

    def __init__(self, base_url: str = None, api_key: str = None, mock: bool = True):
        self.base_url = base_url or "https://api.sensr.it/v1"
        self.api_key = api_key
        self.mock = mock
        self.generator = MockDataGenerator()
        mode = "MOCK" if mock else "PRODUÇÃO"
        logger.info(f"[SensrAPIClient] Inicializado | Modo: {mode} | URL: {self.base_url}")

    def get_tickets(self, status: str = None, category: str = None,
                    priority: str = None, limit: int = 200) -> list:
        """Retorna lista de chamados de suporte."""
        if self.mock:
            tickets = self.generator.generate_tickets(limit)
            if status:
                tickets = [t for t in tickets if t["status"] == status]
            if priority:
                tickets = [t for t in tickets if t["priority"] == priority]
            logger.info(f"[SensrAPIClient] GET /tickets → {len(tickets)} chamados")
            return tickets
        # Produção: implementar requests.get(...)
        raise NotImplementedError("Modo produção: configure BASE_URL e API_KEY")

    def get_ticket(self, ticket_id: str) -> dict:
        """Retorna detalhe de um chamado específico."""
        if self.mock:
            tickets = self.generator.generate_tickets(1)
            tickets[0]["id"] = ticket_id
            return tickets[0]
        raise NotImplementedError

    def get_projects(self, status: str = None, limit: int = 50) -> list:
        """Retorna lista de projetos."""
        if self.mock:
            projects = self.generator.generate_projects(limit)
            if status:
                projects = [p for p in projects if p["status"] == status]
            logger.info(f"[SensrAPIClient] GET /projects → {len(projects)} projetos")
            return projects
        raise NotImplementedError

    def get_sla_report(self, period_days: int = 30) -> dict:
        """Retorna relatório consolidado de SLA."""
        if self.mock:
            report = self.generator.generate_sla_report(period_days)
            logger.info(f"[SensrAPIClient] GET /sla → período: {period_days} dias")
            return report
        raise NotImplementedError

    def get_kpis(self) -> dict:
        """Retorna KPIs gerenciais consolidados."""
        if self.mock:
            kpis = self.generator.generate_kpis()
            logger.info(f"[SensrAPIClient] GET /kpis → {len(kpis)} métricas")
            return kpis
        raise NotImplementedError

    def get_categories(self) -> list:
        """Retorna categorias de chamados."""
        return MockDataGenerator.CATEGORIES

    def get_agents(self) -> list:
        """Retorna agentes/atendentes."""
        return MockDataGenerator.AGENTS


