<script>
const TICKETS = {tickets_json};
const PROJECTS = {projects_json};
const SLA = {sla_json};
const KPIS = {kpis_json};
const TIMELINE = {timeline_json};
const AI = {ai_json};

const COLORS = {{
  blue:'#3b82f6', green:'#22c55e', orange:'#f97316',
  red:'#ef4444', purple:'#a855f7', yellow:'#eab308',
  teal:'#14b8a6', pink:'#ec4899'
}};
const CHART_COLORS = Object.values(COLORS);

function showPage(name) {{
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  event.target.classList.add('active');
}}

function priorityPill(p) {{
  const map = {{'Crítica':'pill-red','Alta':'pill-orange','Média':'pill-yellow','Baixa':'pill-green'}};
  return `<span class="pill ${{map[p]||'pill-blue'}}">${{p}}</span>`;
}}

function statusPill(s) {{
  const map = {{'Aberto':'pill-orange','Em Andamento':'pill-blue','Resolvido':'pill-green','Fechado':'pill-green','Aguardando Usuário':'pill-yellow','Em Execução':'pill-blue','Concluído':'pill-green','Planejamento':'pill-purple','Pausado':'pill-yellow','Em Revisão':'pill-blue'}};
  return `<span class="pill ${{map[s]||'pill-blue'}}">${{s}}</span>`;
}}

function riskPill(r) {{
  const map = {{'Alto':'pill-red','Médio':'pill-orange','Baixo':'pill-green'}};
  return `<span class="pill ${{map[r]||'pill-blue'}}">${{r}}</span>`;
}}

function makeChart(id, type, labels, datasets, opts={{}}) {{
  const ctx = document.getElementById(id);
  if(!ctx) return;
  return new Chart(ctx, {{
    type, data:{{labels, datasets}},
    options:{{
      responsive:true, maintainAspectRatio:false,
      plugins:{{legend:{{labels:{{color:'#94a3b8',font:{{size:11}}}}}}}},
      scales: type==='bar'||type==='line' ? {{
        x:{{ticks:{{color:'#94a3b8',font:{{size:10}}}},grid:{{color:'#1e293b'}}}},
        y:{{ticks:{{color:'#94a3b8',font:{{size:10}}}},grid:{{color:'#334155'}}}}
      }} : undefined,
      ...opts
    }}
  }});
}}

function init() {{
  // KPIs Overview
  document.getElementById('kpi-total-tickets').textContent = TICKETS.total?.toLocaleString('pt-BR') || '—';
  document.getElementById('kpi-open-tickets').textContent = (TICKETS.open||0) + ' em aberto';
  document.getElementById('kpi-active-projects').textContent = PROJECTS.active || '—';
  document.getElementById('kpi-completed-projects').textContent = (PROJECTS.completed||0) + ' concluídos';
  document.getElementById('kpi-sla').textContent = (SLA.overall?.compliance_pct||0) + '%';
  document.getElementById('kpi-satisfaction').textContent = (TICKETS.avg_satisfaction||0).toFixed(1);

  // Timeline Chart
  makeChart('chart-timeline','line',TIMELINE.labels,[
    {{label:'Abertos',data:TIMELINE.created,borderColor:COLORS.orange,backgroundColor:'rgba(249,115,22,0.1)',tension:.4,fill:true}},
    {{label:'Resolvidos',data:TIMELINE.resolved,borderColor:COLORS.green,backgroundColor:'rgba(34,197,94,0.1)',tension:.4,fill:true}},
  ]);

  // Priority Overview
  const byPrio = TICKETS.by_priority||{{}};
  makeChart('chart-priority-overview','doughnut',Object.keys(byPrio),[{{
    data:Object.values(byPrio),
    backgroundColor:[COLORS.red,COLORS.orange,COLORS.yellow,COLORS.green],
    borderWidth:0
  }}]);

  // Project Status Overview
  const byStatus = PROJECTS.by_status||{{}};
  makeChart('chart-proj-status-overview','doughnut',Object.keys(byStatus),[{{
    data:Object.values(byStatus),
    backgroundColor:CHART_COLORS,borderWidth:0
  }}]);

  // SLA bars overview
  const slaBarsEl = document.getElementById('sla-bars-overview');
  if(slaBarsEl && SLA.by_priority) {{
    slaBarsEl.innerHTML = Object.entries(SLA.by_priority).map(([p,v])=>{{
      const color = v.compliance_pct>=90?'#22c55e':v.compliance_pct>=75?'#f97316':'#ef4444';
      return `<div style="margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:4px">
          <span>${{p}}</span><span style="color:${{color}};font-weight:500">${{v.compliance_pct}}%</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" style="width:${{v.compliance_pct}}%;background:${{color}}"></div></div>
      </div>`;
    }}).join('');
  }}

  // AI Alerts
  const alertsEl = document.getElementById('ai-alerts-overview');
  if(alertsEl && AI.tickets?.insights) {{
    alertsEl.innerHTML = AI.tickets.insights.slice(0,4).map(i=>
      `<div class="insight-item"><span class="insight-icon">💡</span><span class="insight-text">${{i}}</span></div>`
    ).join('');
  }}

  // ── TICKETS PAGE ──
  document.getElementById('t-open').textContent = TICKETS.open||'—';
  document.getElementById('t-critical').textContent = TICKETS.critical_open||'—';
  document.getElementById('t-avg-res').textContent = (TICKETS.avg_resolution_hours||0)+'h';
  document.getElementById('t-reopen').textContent = (TICKETS.reopen_rate_pct||0)+'%';

  const byCat = TICKETS.by_category||{{}};
  makeChart('chart-category','bar',Object.keys(byCat),[{{
    label:'Tickets',data:Object.values(byCat),
    backgroundColor:COLORS.blue,borderRadius:4,borderSkipped:false
  }}],{{indexAxis:'y'}});

  const byAgent = TICKETS.by_agent||{{}};
  makeChart('chart-agent','bar',Object.keys(byAgent),[{{
    label:'Tickets',data:Object.values(byAgent),
    backgroundColor:COLORS.purple,borderRadius:4,borderSkipped:false
  }}],{{indexAxis:'y'}});

  // Tickets table
  const tbody = document.getElementById('tickets-table');
  if(tbody && TICKETS.raw) {{
    tbody.innerHTML = TICKETS.raw.slice(0,20).map(t=>{{
      const date = t.created_at?.substring(0,10)||'';
      return `<tr>
        <td style="font-family:monospace;color:var(--blue-light)">${{t.id}}</td>
        <td>${{t.title}}</td>
        <td><span class="pill pill-blue">${{t.category}}</span></td>
        <td>${{priorityPill(t.priority)}}</td>
        <td>${{statusPill(t.status)}}</td>
        <td>${{t.agent}}</td>
        <td style="color:var(--muted)">${{date}}</td>
      </tr>`;
    }}).join('');
  }}

  // ── PROJECTS PAGE ──
  document.getElementById('p-active').textContent = PROJECTS.active||'—';
  document.getElementById('p-completed').textContent = PROJECTS.completed||'—';
  document.getElementById('p-risk').textContent = PROJECTS.at_risk||'—';
  const bv = PROJECTS.budget_variance_pct||0;
  document.getElementById('p-budget').textContent = (bv>0?'+':'')+bv+'%';

  const pByStatus = PROJECTS.by_status||{{}};
  makeChart('chart-proj-status','doughnut',Object.keys(pByStatus),[{{
    data:Object.values(pByStatus),backgroundColor:CHART_COLORS,borderWidth:0
  }}]);

  const pByRisk = PROJECTS.by_risk||{{}};
  makeChart('chart-proj-risk','doughnut',Object.keys(pByRisk),[{{
    data:Object.values(pByRisk),
    backgroundColor:[COLORS.green,COLORS.orange,COLORS.red],borderWidth:0
  }}]);

  // Projects table
  const ptbody = document.getElementById('projects-table');
  if(ptbody && PROJECTS.raw) {{
    ptbody.innerHTML = PROJECTS.raw.map(p=>{{
      const bcolor = p.budget_variance_pct>10?'var(--red)':p.budget_variance_pct>0?'var(--orange)':'var(--green)';
      return `<tr>
        <td style="font-family:monospace;color:var(--blue-light)">${{p.id}}</td>
        <td style="max-width:200px">${{p.name}}</td>
        <td>${{statusPill(p.status)}}</td>
        <td>
          <div style="display:flex;align-items:center;gap:8px">
            <div class="progress-bar" style="width:80px;height:8px"><div class="progress-fill" style="width:${{p.progress_pct}}%;background:var(--blue)"></div></div>
            <span style="font-size:.8rem">${{p.progress_pct}}%</span>
          </div>
        </td>
        <td>R$ ${{(p.budget_planned/1000).toFixed(0)}}k</td>
        <td style="color:${{bcolor}};font-weight:500">${{p.budget_variance_pct>0?'+':''}}${{p.budget_variance_pct}}%</td>
        <td>${{riskPill(p.risks)}}</td>
        <td style="color:var(--muted)">${{p.manager}}</td>
      </tr>`;
    }}).join('');
  }}

  // ── SLA PAGE ──
  document.getElementById('sla-overall').textContent = (SLA.overall?.compliance_pct||0)+'%';
  document.getElementById('sla-total').textContent = SLA.overall?.total_tickets||'—';
  document.getElementById('sla-breached').textContent = SLA.overall?.sla_breached||'—';
  document.getElementById('sla-critical').textContent = (SLA.by_priority?.['Crítica']?.compliance_pct||0)+'%';

  const slaP = SLA.by_priority||{{}};
  makeChart('chart-sla-priority','bar',Object.keys(slaP),[
    {{label:'Conformidade %',data:Object.values(slaP).map(v=>v.compliance_pct),backgroundColor:Object.values(slaP).map(v=>v.compliance_pct>=90?COLORS.green:v.compliance_pct>=75?COLORS.orange:COLORS.red),borderRadius:4,borderSkipped:false}},
  ]);

  const slaC = SLA.by_category||{{}};
  makeChart('chart-sla-category','bar',Object.keys(slaC),[
    {{label:'Conformidade %',data:Object.values(slaC).map(v=>v.compliance_pct),backgroundColor:COLORS.teal,borderRadius:4,borderSkipped:false}},
  ],{{indexAxis:'y'}});

  // ── AI PAGE ──
  const renderInsights = (el, insights) => {{
    if(!el||!insights) return;
    el.innerHTML = insights.map(i=>
      `<div class="insight-item"><span class="insight-icon">💡</span><span class="insight-text">${{i}}</span></div>`
    ).join('');
  }};
  renderInsights(document.getElementById('ai-tickets-insights'), AI.tickets?.insights);
  renderInsights(document.getElementById('ai-projects-insights'), AI.projects?.insights);
  renderInsights(document.getElementById('ai-sla-insights'), AI.sla?.insights);

  const recEl = document.getElementById('ai-recommendations');
  if(recEl && AI.recommendations?.recommendations) {{
    recEl.innerHTML = AI.recommendations.recommendations.map(r=>{{
      const cls = r.priority==='URGENTE'?'rec-urgent':r.priority==='ALTA'?'rec-high':r.priority==='MÉDIA'?'rec-medium':'rec-low';
      const color = r.priority==='URGENTE'?'#f87171':r.priority==='ALTA'?'#fb923c':r.priority==='MÉDIA'?'#93c5fd':'#4ade80';
      return `<div class="rec-item ${{cls}}">
        <div class="rec-label" style="color:${{color}}">${{r.priority}} — ${{r.area}}</div>
        <div class="rec-text">${{r.action}}</div>
      </div>`;
    }}).join('');
  }}
}}

document.addEventListener('DOMContentLoaded', init);
</script>
</body></html>"""

        path = self.output_dir / "index.html"
        path.write_text(html, encoding="utf-8")
        logger.info(f"[DashboardGenerator] ✅ Dashboard gerado: {path}")
        return str(path)
