"""
sensr.IT — Dashboard HTML Generator
Gera o dashboard HTML/JS completo com todos os dados processados.
"""

import json
import logging
from datetime import datetime
from pathlib import Path

logger = logging.getLogger("DashboardGenerator")


class DashboardGenerator:
    def __init__(self, output_dir: str = "dashboard"):
        self.output_dir = Path(output_dir)
        self.output_dir.mkdir(exist_ok=True)

    def generate(self, data: dict, ai_insights: dict = None) -> str:
        t = data.get("tickets", {})
        p = data.get("projects", {})
        s = data.get("sla", {})
        k = data.get("kpis", {})
        timeline = data.get("timeline", {})
        ai = ai_insights or {}

        tickets_json = json.dumps(t, ensure_ascii=False)
        projects_json = json.dumps(p, ensure_ascii=False)
        sla_json = json.dumps(s, ensure_ascii=False)
        kpis_json = json.dumps(k, ensure_ascii=False)
        timeline_json = json.dumps(timeline, ensure_ascii=False)
        ai_json = json.dumps(ai, ensure_ascii=False)

        sla_pct = s.get("overall", {}).get("compliance_pct", 0)
        sla_color = "#22c55e" if sla_pct >= 90 else "#f97316" if sla_pct >= 75 else "#ef4444"

        html = f"""<!DOCTYPE html>
<html lang="pt-BR">
