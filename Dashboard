<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>sensr.IT — ITSM Intelligence Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  :root {{
    --bg: #0f172a; --surface: #1e293b; --surface2: #273549;
    --border: #334155; --blue: #3b82f6; --blue-light: #60a5fa;
    --green: #22c55e; --orange: #f97316; --red: #ef4444;
    --purple: #a855f7; --text: #f1f5f9; --muted: #94a3b8;
  }}
  * {{ margin:0; padding:0; box-sizing:border-box; }}
  body {{ font-family:'Segoe UI',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }}

  /* HEADER */
  .header {{ background:linear-gradient(135deg,#1e3a5f,#0f172a); border-bottom:1px solid #1e40af; padding:0 32px; height:64px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }}
  .header-left {{ display:flex; align-items:center; gap:16px; }}
  .logo {{ font-size:1.3rem; font-weight:700; color:var(--blue-light); }}
  .logo span {{ color:var(--text); }}
  .badge {{ background:#1e40af; color:#93c5fd; padding:4px 10px; border-radius:20px; font-size:0.72rem; border:1px solid #3b82f6; }}
  .updated {{ color:var(--muted); font-size:0.78rem; }}

  /* NAV TABS */
  .tabs {{ display:flex; gap:4px; background:var(--surface2); padding:4px; border-radius:10px; margin:24px 32px 0; }}
  .tab {{ padding:10px 20px; border-radius:7px; cursor:pointer; font-size:0.85rem; color:var(--muted); border:none; background:transparent; transition:all .2s; }}
  .tab.active {{ background:var(--blue); color:#fff; font-weight:500; }}
  .tab:hover:not(.active) {{ background:var(--surface); color:var(--text); }}

  /* LAYOUT */
  .container {{ padding:24px 32px; }}
  .page {{ display:none; }}
  .page.active {{ display:block; }}
  .grid-4 {{ display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }}
  .grid-3 {{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }}
  .grid-2 {{ display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-bottom:24px; }}
  .grid-2-1 {{ display:grid; grid-template-columns:2fr 1fr; gap:16px; margin-bottom:24px; }}
  .grid-1-2 {{ display:grid; grid-template-columns:1fr 2fr; gap:16px; margin-bottom:24px; }}

  /* CARDS */
  .card {{ background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px; }}
  .card-header {{ display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid var(--border); }}
  .card-title {{ font-size:0.88rem; font-weight:500; color:var(--blue-light); }}

  /* KPI CARDS */
  .kpi {{ background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px; }}
  .kpi-label {{ font-size:0.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }}
  .kpi-value {{ font-size:2rem; font-weight:700; }}
  .kpi-sub {{ font-size:0.75rem; color:var(--muted); margin-top:4px; }}
  .kpi-icon {{ font-size:1.5rem; margin-bottom:8px; }}

  /* BADGES */
  .pill {{ display:inline-block; padding:3px 9px; border-radius:20px; font-size:0.72rem; font-weight:500; }}
  .pill-red {{ background:#450a0a; color:#f87171; border:1px solid #991b1b; }}
  .pill-orange {{ background:#431407; color:#fb923c; border:1px solid #9a3412; }}
  .pill-yellow {{ background:#422006; color:#fbbf24; border:1px solid #92400e; }}
  .pill-green {{ background:#052e16; color:#4ade80; border:1px solid #166534; }}
  .pill-blue {{ background:#1e3a5f; color:#93c5fd; border:1px solid #1e40af; }}
  .pill-purple {{ background:#3b0764; color:#d8b4fe; border:1px solid #7e22ce; }}

  /* TABLE */
  .table-wrap {{ overflow-x:auto; }}
  table {{ width:100%; border-collapse:collapse; font-size:0.82rem; }}
  th {{ color:var(--muted); font-weight:500; padding:10px 12px; text-align:left; border-bottom:1px solid var(--border); font-size:0.75rem; text-transform:uppercase; letter-spacing:.5px; }}
  td {{ padding:10px 12px; border-bottom:1px solid var(--border); color:var(--text); }}
  tr:hover td {{ background:var(--surface2); }}
  tr:last-child td {{ border-bottom:none; }}

  /* PROGRESS BAR */
  .progress-bar {{ height:6px; background:var(--border); border-radius:4px; overflow:hidden; margin-top:6px; }}
  .progress-fill {{ height:100%; border-radius:4px; transition:width .5s; }}

  /* AI INSIGHTS */
  .insight-item {{ display:flex; gap:12px; padding:12px; background:var(--surface2); border-radius:8px; margin-bottom:8px; border-left:3px solid var(--blue); }}
  .insight-icon {{ font-size:1rem; flex-shrink:0; }}
  .insight-text {{ font-size:0.85rem; color:#bfdbfe; line-height:1.5; }}
  .rec-item {{ padding:12px 14px; border-radius:8px; margin-bottom:8px; }}
  .rec-urgent {{ background:#450a0a; border-left:3px solid var(--red); }}
  .rec-high {{ background:#431407; border-left:3px solid var(--orange); }}
  .rec-medium {{ background:#1e3a5f; border-left:3px solid var(--blue); }}
  .rec-low {{ background:#052e16; border-left:3px solid var(--green); }}
  .rec-label {{ font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px; }}
  .rec-text {{ font-size:0.83rem; }}

  /* SLA METER */
  .sla-ring {{ text-align:center; padding:16px; }}
  .sla-number {{ font-size:2.5rem; font-weight:700; }}
  .sla-label {{ font-size:0.75rem; color:var(--muted); }}

  /* CHART CONTAINER */
  .chart-wrap {{ position:relative; height:220px; }}
  .chart-wrap-sm {{ position:relative; height:180px; }}
  .chart-wrap-lg {{ position:relative; height:280px; }}
</style>
</head>
